{
    "display_information": {
        "name": "seuron",
        "description": "SEUnglab neuRON pipeline task manager"
    },
    "features": {
        "bot_user": {
            "display_name": "seuronbot",
            "always_online": true
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "chat:write",
                "chat:write.customize",
                "files:read",
                "files:write",
                "users:read",
                "reactions:read",
                "reactions:write",
                "channels:history",
                "groups:history",
                "im:history",
                "mpim:history",
                "channels:read"
            ]
        }
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "message.channels",
                "message.groups",
                "message.im",
                "message.mpim",
                "reaction_added"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true
    }
}
